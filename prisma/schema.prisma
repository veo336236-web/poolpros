generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BusinessRegistration {
  id           Int      @id @default(autoincrement())
  businessName String
  ownerName    String
  phone        String
  category     String
  governorate  String
  description  String   @default("")
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}
